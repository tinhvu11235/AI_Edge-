FROM python:3.11-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /opt/edge-assistant

COPY requirements.txt README.md ./
COPY configs ./configs
COPY edge_assistant ./edge_assistant
COPY benchmarks ./benchmarks
COPY tests ./tests

RUN python -m compileall edge_assistant benchmarks tests

CMD ["python", "-m", "benchmarks.bench_pipeline", "--config", "configs/pipeline.sim.toml", "--mode", "active", "--duration", "30", "--out", "outputs/benchmark.active.json"]
